{
  "name": "tryiton",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for the TryItOn virtual try-on API.",
  "keywords": [
    "tryiton",
    "virtual-try-on",
    "tryon",
    "fashion",
    "ai",
    "sdk"
  ],
  "homepage": "https://docs.tryiton.now",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryiton-now/tryiton-node.git"
  },
  "bugs": {
    "url": "https://github.com/tryiton-now/tryiton-node/issues"
  },
  "license": "MIT",
  "author": "TryItOn",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
